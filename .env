# MongoDB
MONGO_URL=mongodb://messenger_admin:SecurePassword123@localhost:27017/messenger?authSource=admin

# JWT
JWT_SECRET=MIET
JWT_REFRESH_SECRET=MIET
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@messenger.local

# Server
PORT=3000
NODE_ENV=production
HOST=0.0.0.0

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
